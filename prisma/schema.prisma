// Prisma schema for Joe's Used Harleys
// Target database: Supabase PostgreSQL (free tier)
// Connection strings live in prisma.config.ts / .env — see .env.example

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum BikeStatus {
  AVAILABLE
  PENDING
  SOLD
}

enum LeadType {
  CONTACT
  PREAPPROVAL
  FACETIME
  ALERT
  AI_HANDOFF
}

enum LeadStatus {
  NEW
  CONTACTED
  CLOSED
}

model Bike {
  id          String       @id @default(cuid())
  vin         String?
  title       String
  model       String
  year        Int
  mileage     Int?
  price       Int?
  status      BikeStatus   @default(AVAILABLE)
  description String?
  slug        String       @unique
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  photos      BikePhoto[]
  leads       Lead[]

  @@index([status])
  @@index([model])
}

model BikePhoto {
  id        String   @id @default(cuid())
  bikeId    String
  bike      Bike     @relation(fields: [bikeId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([bikeId])
}

model Lead {
  id         String     @id @default(cuid())
  name       String
  email      String?
  phone      String?
  message    String?
  sourcePage String?
  type       LeadType   @default(CONTACT)
  status     LeadStatus @default(NEW)
  bikeId     String?
  bike       Bike?      @relation(fields: [bikeId], references: [id], onDelete: SetNull)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([status])
  @@index([type])
  @@index([createdAt])
}

model AlertSubscription {
  id        String   @id @default(cuid())
  email     String
  model     String   @default("")
  maxPrice  Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([email, model, maxPrice])
  @@index([active])
}

model Testimonial {
  id        String   @id @default(cuid())
  author    String
  text      String
  source    String?
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([approved])
}

model Post {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  excerpt     String?
  body        String
  category    String?
  published   Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([published])
  @@index([category])
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Conversation {
  id        String    @id @default(cuid())
  sessionId String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  messages  Message[]
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String
  createdAt      DateTime     @default(now())

  @@index([conversationId])
}
