// Core CRM schema for Joe's Used Harleys.
// Capture and manage buyers — Lead, Bike, Interaction only.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum LeadStatus {
  NEW
  CONTACTED
  CLOSED
}

enum BikeStatus {
  AVAILABLE
  PENDING
  SOLD
}

enum InteractionType {
  PHONE_CALL
  TEXT
  VISIT
  EMAIL
  TEST_RIDE
}

model Lead {
  id           String        @id @default(cuid())
  name         String
  email        String?
  phone        String?
  source       String?
  status       LeadStatus    @default(NEW)
  notes        String?
  createdAt    DateTime      @default(now())
  interactions Interaction[]

  @@index([status])
  @@index([createdAt])
}

model Bike {
  id          String     @id @default(cuid())
  year        Int
  make        String
  model       String
  price       Int?
  mileage     Int?
  description String?
  status      BikeStatus @default(AVAILABLE)
  photos      String[]   @default([])
  createdAt   DateTime   @default(now())

  @@index([status])
  @@index([make, model])
}

model Interaction {
  id        String          @id @default(cuid())
  leadId    String
  lead      Lead            @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type      InteractionType
  note      String?
  createdAt DateTime        @default(now())

  @@index([leadId])
  @@index([createdAt])
}
