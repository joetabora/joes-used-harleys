# =============================================================================
# Joe's Used Harleys — environment placeholders
# Copy to .env.local (and Vercel project env) and replace PLACEHOLDER values.
# Do not invent or commit real credentials.
# =============================================================================

# --- Supabase PostgreSQL (required for inventory, leads, admin) ---
# Pooled connection (Transaction mode / port 6543) — used by the Next.js app
DATABASE_URL="postgresql://postgres.PLACEHOLDER_PROJECT_REF:PLACEHOLDER_PASSWORD@aws-0-PLACEHOLDER_REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct / session connection (port 5432) — used by Prisma migrations
DIRECT_URL="postgresql://postgres.PLACEHOLDER_PROJECT_REF:PLACEHOLDER_PASSWORD@aws-0-PLACEHOLDER_REGION.pooler.supabase.com:5432/postgres"

# Supabase project (for Storage photo uploads in Phase 2)
NEXT_PUBLIC_SUPABASE_URL="https://PLACEHOLDER_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="PLACEHOLDER_SUPABASE_ANON_KEY"
SUPABASE_SERVICE_ROLE_KEY="PLACEHOLDER_SUPABASE_SERVICE_ROLE_KEY"
SUPABASE_STORAGE_BUCKET="bike-photos"

# --- Site / contact ---
NEXT_PUBLIC_SITE_URL="https://joesusedharleys.com"
NEXT_PUBLIC_JOE_PHONE="PLACEHOLDER_PHONE_E164"
NEXT_PUBLIC_JOE_EMAIL="PLACEHOLDER_JOE_EMAIL@example.com"
NEXT_PUBLIC_JOE_SMS_LINK="sms:PLACEHOLDER_PHONE_E164"

# --- Lead notification email (Resend free tier) ---
# Leave unset to store leads in DB only (no outbound email).
RESEND_API_KEY="PLACEHOLDER_RESEND_API_KEY"
LEAD_NOTIFY_EMAIL="PLACEHOLDER_JOE_EMAIL@example.com"
EMAIL_FROM="Joe's Used Harleys <onboarding@resend.dev>"

# --- Admin access (simple cookie session; replace with Supabase Auth later if desired) ---
ADMIN_EMAIL="PLACEHOLDER_ADMIN_EMAIL@example.com"
ADMIN_PASSWORD="PLACEHOLDER_ADMIN_PASSWORD"
# Optional: 32+ char secret for signing the admin session cookie
ADMIN_SESSION_SECRET="PLACEHOLDER_RANDOM_SECRET_AT_LEAST_32_CHARS"

# --- Phase 4: AI assistant (optional; feature stays disabled without a key) ---
# OPENAI_API_KEY="PLACEHOLDER_OPENAI_API_KEY"
# AI_MODEL="gpt-4o-mini"
